# ShowPulse Configuration

# Server port (default: 3000)
PORT=3000

# Admin PIN for write access (leave empty for open dev mode)
SHOWPULSE_ADMIN_PIN=

# Enable demo mode with simulated timecode (no hardware needed)
SHOWPULSE_DEMO=false

# Default frame rate (24, 25, 29.97, 30)
SHOWPULSE_FPS=30

# SQLite database path
SHOWPULSE_DB_PATH=./data/showpulse.db

# Session secret for cookie signing
SESSION_SECRET=change-me-in-production

# LTC sidecar Python path (auto-detected if not set)
SHOWPULSE_PYTHON_PATH=

# mDNS service name
SHOWPULSE_MDNS_NAME=ShowPulse
